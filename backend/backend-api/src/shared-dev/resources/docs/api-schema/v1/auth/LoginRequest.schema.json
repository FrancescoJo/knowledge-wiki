{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoginRequest",
  "description": "Credentials submitted as application/x-www-form-urlencoded.",
  "type": "object",
  "required": [
    "email",
    "password"
  ],
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "description": "Registered email address.",
      "example": "user@example.com"
    },
    "password": {
      "type": "string",
      "format": "password",
      "description": "Account password.",
      "example": "s3cr3t!"
    }
  }
}
