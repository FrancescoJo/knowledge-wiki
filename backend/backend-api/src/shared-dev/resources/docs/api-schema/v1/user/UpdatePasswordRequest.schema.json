{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UpdatePasswordRequest",
  "description": "Payload to change the password of an existing user account.",
  "type": "object",
  "required": [
    "password"
  ],
  "properties": {
    "password": {
      "type": "string",
      "format": "password",
      "description": "New password.",
      "example": "newS3cr3t!"
    }
  }
}
